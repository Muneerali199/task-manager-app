{
  "builds": [
    { "src": "backend/**", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/(.+)", "dest": "frontend/dist/$1" },
    { "src": "/", "dest": "frontend/dist/index.html" }
  ]
}